{
  "name": "eways-revamp",
  "version": "1.0.0",
  "description": "EWAYS - Modern Business Solutions Platform (Full Stack)",
  "private": true,
  "workspaces": [
    "eways-frontend",
    "eways-backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd eways-frontend && npm run dev",
    "dev:backend": "cd eways-backend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd eways-frontend && npm run build",
    "build:backend": "cd eways-backend && npm run build",
    "start": "cd eways-backend && npm start",
    "install:all": "npm install && cd eways-frontend && npm install && cd ../eways-backend && npm install",
    "clean": "cd eways-frontend && npm run clean"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "author": "EWAYS Team",
  "license": "MIT"
}
