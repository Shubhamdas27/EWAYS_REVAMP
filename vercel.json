{
  "version": 2,
  "builds": [
    {
      "src": "eways-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "eways-frontend/dist",
        "buildCommand": "cd eways-frontend && npm run build"
      }
    },
    {
      "src": "eways-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/eways-backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/eways-frontend/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
